# Go API 开发端口；生产环境默认使用 3000
PORT=3001
HOST=127.0.0.1

# 子路径部署示例：https://example.com/mail
VITE_BASE_PATH=/mail/
MAIL_COOKIE_PATH=/mail
MAIL_BIND_PORT=3000

# 首次启动后请在网页中配置管理员；生产环境必须设置至少 32 位会话密钥。
MAIL_SESSION_SECRET=

# 注册与首次管理员初始化所需的邮件验证码服务
# 验证码为 6 位数字，5 分钟有效，同一邮箱 60 秒内只能发送一次
MAIL_VERIFICATION_SMTP_HOST=
MAIL_VERIFICATION_SMTP_PORT=587
MAIL_VERIFICATION_SMTP_SECURE=0
MAIL_VERIFICATION_SMTP_USER=
MAIL_VERIFICATION_SMTP_PASSWORD=
MAIL_VERIFICATION_FROM=

# 仅当服务确实位于可信反向代理之后时设为 1
MAIL_TRUST_PROXY=0

# 生产环境必填：64 位十六进制或 Base64 编码的 32 字节密钥。
# 仅开发环境留空时，才会在 data/.master-key 自动生成本地密钥。
MAIL_ENCRYPTION_KEY=

# 可选：覆盖默认数据目录、前端构建目录和微软邮件服务器
MAIL_DATA_DIR=./data
MAIL_WEB_ROOT=./dist
OUTLOOK_IMAP_HOST=outlook.office365.com
OUTLOOK_SMTP_HOST=smtp-mail.outlook.com
